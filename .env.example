# Feishu Bot Configuration
# Get these from https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Optional: Verification token for webhook mode
FEISHU_VERIFICATION_TOKEN=

# Connection mode: "long_connection" (WebSocket) or "webhook"
# Default: long_connection (recommended)
FEISHU_CONNECTION_MODE=long_connection

# Allow specific user IDs (comma-separated, empty = allow all)
FEISHU_ALLOW_USER_IDS=

# Allow group chats (true/false, default: true)
FEISHU_ALLOW_GROUP_CHATS=true

# Claude Code Configuration
# Working directory for Claude Code sessions (default: current directory)
CLAUDE_WORKSPACE=.

# Claude model to use (optional, uses Claude Code default)
# CLAUDE_MODEL=claude-sonnet-4-6

# Maximum turns per Claude session (optional)
# CLAUDE_MAX_TURNS=10
