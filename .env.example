# Feishu Bot Configuration
# Get these from https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Optional: Verification token for webhook mode
FEISHU_VERIFICATION_TOKEN=

# Connection mode: "long_connection" (WebSocket) or "webhook"
# Default: long_connection (recommended)
FEISHU_CONNECTION_MODE=long_connection

# Backend selector during migration: "claude" or "codex"
# Default: claude (will switch to codex in final rollout phase)
FEISHU_BACKEND=claude

# Allow specific user IDs (comma-separated, empty = allow all)
FEISHU_ALLOW_USER_IDS=

# Allow group chats (true/false, default: true)
FEISHU_ALLOW_GROUP_CHATS=true

# Default response language (zh|en)
FEISHU_DEFAULT_LANGUAGE=zh

# Long-task progress update controls
# FEISHU_PROGRESS_UPDATES_ENABLED=true
# FEISHU_PROGRESS_EVENT_INTERVAL=30
# FEISHU_PROGRESS_MIN_SECONDS=8
# FEISHU_PROGRESS_MIN_INTERVAL_SECONDS=2
# FEISHU_DEFAULT_TURN_LIMIT=20
# FEISHU_DEFAULT_BUDGET_USD=5.0

# Claude Code Configuration
# Working directory for Claude Code sessions (default: current directory)
CLAUDE_WORKSPACE=.

# Claude model to use (optional, uses Claude Code default)
# CLAUDE_MODEL=claude-sonnet-4-6

# Maximum turns per Claude session (optional)
# CLAUDE_MAX_TURNS=10

# Codex Configuration
# Working directory for Codex sessions (default: CLAUDE_WORKSPACE/current directory)
# CODEX_WORKSPACE=.

# Codex model override (optional)
# CODEX_MODEL=gpt-5-codex

# Enable web search in Codex by default (true/false)
# CODEX_SEARCH_ENABLED=false

# Default Codex mode (safe|normal|full)
# CODEX_DEFAULT_MODE=safe

# Optional execpolicy rule files (comma-separated)
# CODEX_EXECPOLICY_RULES=/path/to/rules-1.json,/path/to/rules-2.json
